# Local dev (recommended): leave NEXT_PUBLIC_API_URL unset so the browser calls
# /api/* on the same host as Next.js; next.config.ts proxies to FastAPI (127.0.0.1:8000).
# That avoids CORS issues (localhost vs 127.0.0.1 are different origins).

# If the API is on another machine or you skip the proxy, set the full origin:
# NEXT_PUBLIC_API_URL=https://your-api.example.com

# Optional: where Next.js should proxy /api (default http://127.0.0.1:8000)
# API_PROXY_TARGET=http://127.0.0.1:8000
