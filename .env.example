# Optional overrides (all keys have sensible defaults in code)
DATABASE_PATH=data/bot.db
REPORTS_DIR=reports
RAW_NEWS_DIR=data/raw_news

# Paper trading notional (USD) used to size BTC quantity
PAPER_TRADE_USD=100

# CoinGecko (free, no key required). Set if you self-host or use Pro.
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
# Reduce 429s: in-process response cache (seconds). Set 0 to disable caching.
COINGECKO_CACHE_TTL=120
COINGECKO_CACHE_ENABLED=true
COINGECKO_MAX_RETRIES=5

# FinBERT model id (Hugging Face)
FINBERT_MODEL=ProsusAI/finbert

# ML (optional): after `btc-paper-export-ml-features` + `btc-paper-train-ml`, set MODELS_DIR and enable
# ML_ENABLED=true
# MODELS_DIR=models
# SIGNAL_NEWS_WEIGHT=0.3
# SIGNAL_TECH_WEIGHT=0.3
# SIGNAL_ML_WEIGHT=0.4
